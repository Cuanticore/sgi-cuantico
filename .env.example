PORT=3004
DEV_MODE=false
PUBLIC_URL=https://sig.cuantico.com
AZURE_REDIRECT_URI=https://your-domain/api/auth/callback/azure-ad

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-domain
NEXTAUTH_SECRET=your-nextauth-secret

# ─── Azure AD (autenticación) ─────────────────────────────────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── SharePoint / Microsoft Graph ─────────────────────────────────────────────
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_URL=yourorg.sharepoint.com
SHAREPOINT_SITE_NAME=YourSite

# Rutas a los archivos Excel en SharePoint
SHAREPOINT_INDICATORS_PATH=
SHAREPOINT_INDICATORS_FILE=
SHAREPOINT_INDICATORS_PATH_2025=
SHAREPOINT_INDICATORS_FILE_2025=

# URLs web de la Matriz de Indicadores (para abrir en SharePoint)
SHAREPOINT_MATRIX_URL_2026=
SHAREPOINT_MATRIX_URL_2025=

# ─── Modo desarrollo (archivos locales) ───────────────────────────────────────
LOCAL_INDICATORS_FILE_2026=
LOCAL_INDICATORS_FILE_2025=
